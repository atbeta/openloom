# OpenLoom — environment configuration
# Copy to .env and fill in your values.

# OpenCode server (must already be running)
OPENLOOM_OPENCODE_URL=http://127.0.0.1:14096
OPENLOOM_OPENCODE_USERNAME=opencode
OPENLOOM_OPENCODE_PASSWORD=change-me

# Storage
# OPENLOOM_DATABASE=.openloom/openloom.sqlite3

# Web UI (openloom watch --ui)
# OPENLOOM_UI_HOST=127.0.0.1
# OPENLOOM_UI_PORT=55413

# Optional: restrict harness workspaces (colon-separated on macOS/Linux)
# OPENLOOM_ALLOWED_ROOTS=/Users/you/Projects:/other/path
# OPENLOOM_STRICT_ROOTS=true
