# OpenLoom — environment configuration
# Copy to .env and fill in your values.

# OpenCode server (must already be running; default port matches `opencode serve`)
OPENLOOM_OPENCODE_URL=http://127.0.0.1:4096
# OPENLOOM_OPENCODE_USERNAME=opencode
# OPENLOOM_OPENCODE_PASSWORD=          # only if OpenCode uses OPENCODE_SERVER_PASSWORD

# Storage
# OPENLOOM_DATABASE=.openloom/openloom.sqlite3

# Web UI (openloom watch --ui)
# OPENLOOM_UI_HOST=127.0.0.1
# OPENLOOM_UI_PORT=55413
